# Copy to .env.local and fill in values. Never commit secrets.

# Session signing secret (any random 32+ chars in dev)
SESSION_SECRET=replace-with-a-long-random-string

# Public app base URL (used in metadata + redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default locale + supported locales (comma-separated)
NEXT_PUBLIC_DEFAULT_LOCALE=es-MX
NEXT_PUBLIC_LOCALES=es-MX,en-US
